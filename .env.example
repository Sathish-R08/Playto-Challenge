# Copy to backend/.env for Django/Celery. Do not put real production secrets in git.
# Values below match docker-compose.yml (user playto / password playto / db playto).

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

DATABASE_URL=postgresql://playto:playto@127.0.0.1:5432/playto

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Windows: default pool is solo (avoids Celery/billiard WinError 5). Linux deploy: prefork
# CELERY_WORKER_POOL=prefork

# Dev: allow any origin. Production: set CORS_ALLOW_ALL=false and CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL=true
# CORS_ALLOWED_ORIGINS=https://your-frontend.example,http://localhost:5173

# Frontend (copy frontend/.env.example to frontend/.env.local — Vite reads VITE_* from there)
